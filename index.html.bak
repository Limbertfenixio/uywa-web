    <!-- ===== SCRIPTS ===== -->
    <script>
        // --- SPA ROUTER SYSTEM ---
        const viewsMap = {
            '#/home': 'view-home',
            '#/guia-adopcion': 'view-guia-adopcion',
            '#/ayuda': 'view-ayuda',
            '#/faqs': 'view-faqs',
            '#/soporte': 'view-soporte',
            '#/terminos': 'view-terminos',
            '#/refugios': 'view-refugios'
        };

        function handleSPA_Routing() {
            const currentHash = window.location.hash || '#home';

            // Cerrar menú móvil al navegar
            navLinks.classList.remove('open');
            navLinks.classList.add('hidden');
            const icon = menuToggle.querySelector('i');
            icon.className = 'fas fa-bars';

            const isSubpage = currentHash.startsWith('#/');

            if (isSubpage) {
                // Ocultar todas las vistas
                document.querySelectorAll('.view-container').forEach(view => {
                    view.classList.remove('active-view');
                });

                // Encontrar y mostrar la vista correspondiente
                const targetViewId = viewsMap[currentHash] || 'view-home';
                const targetViewElement = document.getElementById(targetViewId);

                if (targetViewElement) {
                    targetViewElement.classList.add('active-view');

                    // Efecto Scroll to Top para simular cambio de página nativo
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                }
            } else {
                // Es un enlace de anclaje interno en el home (ej. #features, #simulador)
                // Aseguramos que la vista activa sea únicamente la Home/Landing
                document.querySelectorAll('.view-container').forEach(view => {
                    view.classList.remove('active-view');
                });
                document.getElementById('view-home').classList.add('active-view');

                // Encontramos el elemento objetivo para realizar el scroll con compensación de header
                const targetId = currentHash.substring(1);
                if (targetId) {
                    const targetEl = document.getElementById(targetId);
                    if (targetEl) {
                        const headerOffset = 90;
                        const elementPosition = targetEl.getBoundingClientRect().top;
                        const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

                        window.scrollTo({
                            top: offsetPosition,
                            behavior: 'smooth'
                        });
                    }
                }
            }
        }

        window.addEventListener('hashchange', handleSPA_Routing);
        window.addEventListener('load', () => {
            // Si entra por un enlace vacío, por defecto home
            if (!window.location.hash) {
                window.location.hash = '#home';
            }
            handleSPA_Routing();
        });

        // --- MENÚ HAMBURGUESA MOBILE ---
        const menuToggle = document.getElementById('menuToggle');
        const navLinks = document.getElementById('navLinks');

        menuToggle.addEventListener('click', () => {
            navLinks.classList.toggle('open');
            navLinks.classList.toggle('hidden');
            navLinks.classList.toggle('flex');
            const icon = menuToggle.querySelector('i');
            icon.className = navLinks.classList.contains('open') ? 'fas fa-times' : 'fas fa-bars';
        });

        // --- EFECTO SCROLL HEADER ---
        window.addEventListener('scroll', () => {
            const header = document.getElementById('mainHeader');
            if (window.scrollY > 50) {
                header.classList.add('shadow-md', 'py-3', 'bg-white/95');
                header.classList.remove('py-4', 'bg-white/80');
            } else {
                header.classList.add('py-4', 'bg-white/80');
                header.classList.remove('shadow-md', 'py-3', 'bg-white/95');
            }
        });

        // --- HERO SLIDER (CON ANIMACIÓN DE RETIRO SUPERIOR IZQUIERDA) ---
        /* ===== HERO SLIDER MODERNO ===== */
        let currentSlideIdx = 0;
        const slides = document.querySelectorAll('.hero-slide');
        const dots = document.querySelectorAll('.slider-dot');
        const sliderContainer = document.getElementById('heroSlider');
        let sliderTimer;
        let isPaused = false;

        function updateDots(index) {
            dots.forEach(function(dot, i) {
                if (i === index) {
                    dot.classList.add('active');
                } else {
                    dot.classList.remove('active');
                }
            });
        }

        function showHeroSlide(nextIdx) {
            var currentSlide = slides[currentSlideIdx];
            var nextSlide = slides[nextIdx];

            if (!currentSlide || !nextSlide) return;
            if (currentSlide === nextSlide) return;

            currentSlide.classList.remove('active');
            currentSlide.classList.add('exiting');

            nextSlide.classList.remove('exiting');
            nextSlide.classList.add('entering');

            setTimeout(function() {
                currentSlide.classList.remove('exiting');
                nextSlide.classList.remove('entering');
                nextSlide.classList.add('active');
            }, 950);

            currentSlideIdx = nextIdx;
            updateDots(nextIdx);
        }

        function goToSlide(index) {
            if (index === currentSlideIdx) return;
            showHeroSlide(index);
            resetSliderTimer();
        }

        function nextHeroSlide() {
            var nextIdx = (currentSlideIdx + 1) % slides.length;
            showHeroSlide(nextIdx);
            resetSliderTimer();
        }

        function startSliderTimer() {
            if (sliderTimer) clearInterval(sliderTimer);
            sliderTimer = setInterval(function() {
                if (!isPaused) {
                    nextHeroSlide();
                }
            }, 6000);
        }

        function resetSliderTimer() {
            clearInterval(sliderTimer);
            startSliderTimer();
        }

        dots.forEach(function(dot) {
            dot.addEventListener('click', function() {
                var index = parseInt(this.getAttribute('data-slide'));
                goToSlide(index);
            });
        });

        if (sliderContainer) {
            sliderContainer.addEventListener('mouseenter', function() {
                isPaused = true;
            });
            sliderContainer.addEventListener('mouseleave', function() {
                isPaused = false;
            });
        }

        startSliderTimer();

        // --- INTERACTIVE SIMULATOR (VIRTUAL APP SCREEN) ---
        function switchSimulatorState(stateId, element) {
            document.querySelectorAll('.sim-btn').forEach(btn => btn.classList.remove('active'));
            element.classList.add('active');

            document.querySelectorAll('.sim-state').forEach(state => state.classList.remove('active'));
            document.getElementById(`state-${stateId}`).classList.add('active');
        }

        // --- TESTIMONIALS SLIDER ---
        let testiIdx = 0;
        const testiSlides = document.querySelectorAll('.testi-slide');

        function slideTestimonials(dir) {
            testiSlides[testiIdx].classList.add('hidden');
            testiSlides[testiIdx].classList.remove('active');

            testiIdx += dir;
            if (testiIdx >= testiSlides.length) {
                testiIdx = 0;
            } else if (testiIdx < 0) {
                testiIdx = testiSlides.length - 1;
            }

            testiSlides[testiIdx].classList.remove('hidden');
            testiSlides[testiIdx].classList.add('active');
        }

        // --- SCROLL REVEAL ANIMATIONS ---
        const revealElements = document.querySelectorAll('.reveal');

        function checkReveal() {
            const triggerBottom = window.innerHeight * 0.85;
            revealElements.forEach(el => {
                const elTop = el.getBoundingClientRect().top;
                if (elTop < triggerBottom) {
                    el.classList.add('active');
                }
            });
        }

        window.addEventListener('scroll', checkReveal);
        window.addEventListener('load', checkReveal);

        // --- MODAL DE QR (SOLO PARA QR) ---
        const qrModal = document.getElementById('qrModal');

        function openQrModal(event) {
            event.preventDefault();
            qrModal.classList.add('active');
        }

        function closeQrModal() {
            qrModal.classList.remove('active');
        }

        function closeQrModalOnOverlay(event) {
            if (event.target === qrModal) {
                closeQrModal();
            }
        }

        // --- MODAL "PROXIMAMENTE" (COMING SOON) ---
        const comingSoonModal = document.getElementById('comingSoonModal');

        function openComingSoonModal(event) {
            event.preventDefault();
            comingSoonModal.classList.add('active');
            document.getElementById('subscriptionFeedback').classList.add('hidden');
            document.getElementById('comingSoonEmail').value = '';
        }

        function closeComingSoonModal() {
            comingSoonModal.classList.remove('active');
        }

        function closeComingSoonModalOnOverlay(event) {
            if (event.target === comingSoonModal) {
                closeComingSoonModal();
            }
        }

        function handleNotificationSubscription(event) {
            event.preventDefault();
            const email = document.getElementById('comingSoonEmail').value;
            if (email) {
                const feedback = document.getElementById('subscriptionFeedback');
                feedback.classList.remove('hidden');
                document.getElementById('comingSoonEmail').value = '';

                setTimeout(() => {
                    closeComingSoonModal();
                }, 2200);
            }
        }

        // --- COMPONENTE INTERACTIVO: GUÍA CHECKLIST ---
        function updateAdoptionScore() {
            const totalCheckboxes = document.querySelectorAll('#adoptionChecklist input[type="checkbox"]');
            const checkedBoxes = document.querySelectorAll('#adoptionChecklist input[type="checkbox"]:checked');
            const scoreLabel = document.getElementById('checklistScore');

            scoreLabel.textContent = `${checkedBoxes.length} / ${totalCheckboxes.length} Cumplidos`;
        }

        // --- COMPONENTE INTERACTIVO: CLÍNICAS VETERINARIAS ---
        function filterVets(city) {
            document.querySelectorAll('.vet-filter-btn').forEach(btn => btn.classList.remove('active', 'bg-brand-teal', 'text-white'));
            document.querySelectorAll('.vet-filter-btn').forEach(btn => btn.classList.add('bg-white', 'border', 'border-slate-300', 'text-slate-700'));

            event.target.classList.remove('bg-white', 'border', 'border-slate-300', 'text-slate-700');
            event.target.classList.add('active', 'bg-brand-teal', 'text-white');

            const cards = document.querySelectorAll('#vetsGrid .vet-card');
            cards.forEach(card => {
                if (city === 'all' || card.getAttribute('data-city') === city) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // --- COMPONENTE INTERACTIVO: CATÁLOGO DE REFUGIOS ---
        function filterShelters(city) {
            document.querySelectorAll('.shelter-filter-btn').forEach(btn => btn.classList.remove('active', 'bg-brand-teal', 'text-white'));
            document.querySelectorAll('.shelter-filter-btn').forEach(btn => btn.classList.add('bg-white', 'border', 'border-slate-300', 'text-slate-700'));

            event.target.classList.remove('bg-white', 'border', 'border-slate-300', 'text-slate-700');
            event.target.classList.add('active', 'bg-brand-teal', 'text-white');

            const cards = document.querySelectorAll('#sheltersGrid .shelter-card');
            cards.forEach(card => {
                if (city === 'all' || card.getAttribute('data-city') === city) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // --- COMPONENTE INTERACTIVO: ACORDEÓN DE PREGUNTAS FRECUENTES (FAQS) ---
        function toggleFaq(header) {
            const item = header.parentElement;
            const isActive = item.classList.contains('active');

            // Cerrar todos los demás items
            document.querySelectorAll('.faq-accordion-item').forEach(i => i.classList.remove('active'));

            if (!isActive) {
                item.classList.add('active');
            }
        }

        // --- COMPONENTE INTERACTIVO: SOPORTE TÉCNICO FORM ---
        function handleSupportSubmit(event) {
            event.preventDefault();
            document.getElementById('supportForm').classList.add('hidden');
            document.getElementById('supportSuccess').classList.remove('hidden');
        }

        function resetSupportForm() {
            document.getElementById('supName').value = '';
            document.getElementById('supEmail').value = '';
            document.getElementById('supMsg').value = '';
            document.getElementById('supportForm').classList.remove('hidden');
            document.getElementById('supportSuccess').classList.add('hidden');
        }

        // --- ALERTA INTERNA TOAST (REEMPLAZA AL NATIVO alert()) ---
        function triggerToast(message, icon = 'ℹ️') {
            const toast = document.getElementById('toastAlert');
            const toastMsg = document.getElementById('toastMsg');
            const toastIcon = document.getElementById('toastIcon');

            toastMsg.textContent = message;
            toastIcon.textContent = icon;

            // Mostrar toast
            toast.classList.remove('translate-y-20', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            // Ocultar automáticamente en 3 segundos
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
                toast.classList.remove('translate-y-0', 'opacity-100');
            }, 3000);
        }

        function simulatedAction(event, simulatedMessage) {
            event.preventDefault();
            triggerToast(simulatedMessage, '📱');
        }

        /* ===== Vista previa de capturas de pantalla ===== */
        function openScreenshotPreview(imgSrc, title, description) {
            var overlay = document.createElement('div');
            overlay.className = 'fixed inset-0 bg-black/70 backdrop-blur-md z-[3000] flex items-center justify-center p-4';
            overlay.style.opacity = '0';
            overlay.style.transition = 'opacity 0.3s ease';
            overlay.onclick = function (e) {
                if (e.target === overlay) closePreview(overlay);
            };

            var modal = document.createElement('div');
            modal.className = 'bg-white rounded-[32px] overflow-hidden max-w-[400px] w-full shadow-2xl transform scale-95';
            modal.style.transition = 'transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
            modal.onclick = function (e) { e.stopPropagation(); };

            var html = '';
            html += '<div class="relative">';
            html += '<button onclick="this.closest(\'.fixed\').remove()" class="absolute top-3 right-3 w-8 h-8 bg-black/40 backdrop-blur-sm text-white rounded-full flex items-center justify-center hover:bg-black/60 transition-colors z-10">';
            html += '<i class="fas fa-times text-sm"></i>';
            html += '</button>';
            html += '<div class="bg-slate-950 p-3">';
            html += '<img src="' + imgSrc + '" alt="' + title + '" class="w-full max-h-[65vh] object-contain rounded-2xl mx-auto" onerror="this.src=\'https://placehold.co/400x700/E2E8F0/0F172A?text=' + encodeURIComponent(title) + '\'" />';
            html += '</div>';
            html += '</div>';
            html += '<div class="p-6 text-center">';
            html += '<h3 class="text-xl font-bold text-brand-dark font-Fredoka mb-2">' + title + '</h3>';
            html += '<p class="text-slate-500 text-sm leading-relaxed">' + description + '</p>';
            html += '</div>';

            modal.innerHTML = html;

            overlay.appendChild(modal);
            document.body.appendChild(overlay);

            requestAnimationFrame(function () {
                overlay.style.opacity = '1';
                modal.style.transform = 'scale(1)';
            });

            document.body.style.overflow = 'hidden';
        }

        function closePreview(overlay) {
            overlay.style.opacity = '0';
            var modal = overlay.querySelector('div:first-child');
            if (modal) modal.style.transform = 'scale(0.9)';
            setTimeout(function () {
                overlay.remove();
                document.body.style.overflow = '';
            }, 300);
        }

    </script>
</body>

</html>