<!DOCTYPE html>
<html lang="es" class="scroll-smooth">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>UYWA - Tu App de Mascotas</title>
    <!-- Font Awesome (iconos) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <!-- Google Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            teal: '#5BC0BE',
                            tealHover: '#3A8F8D',
                            orange: '#FF9F1C',
                            dark: '#0F172A',
                            lightBg: '#F8FAFC',
                            cardBg: '#FFFFFF',
                            border: '#E2E8F0'
                        }
                    }
                }
            }
        }
    </script>

    <style>
        /* ===== REGISTRO DE FUENTES Y ESTILOS GLOBALES ===== */
        body {
            font-family: 'Inter', sans-serif;
            background-color: #F8FAFC;
            color: #0F172A;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            font-family: 'Fredoka', sans-serif;
        }

        /* ===== SCROLLBAR PERSONALIZADA ===== */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #F1F5F9;
        }

        ::-webkit-scrollbar-thumb {
            background: #5BC0BE;
            border-radius: 10px;
            border: 2px solid #F1F5F9;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #3A8F8D;
        }

        /* ===== ANIMACIÓN MODERNA DEL HERO SLIDER ===== */
        .slider-container {
            position: relative;
            width: 100%;
            height: 480px;
            overflow: hidden;
            border-radius: 32px;
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
            background: #E2E8F0;
        }

        .slider-container:hover .slider-pause-badge {
            opacity: 1;
            transform: translateY(0);
        }

        .slider-pause-badge {
            position: absolute;
            top: 16px;
            right: 16px;
            z-index: 50;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            color: white;
            font-size: 10px;
            font-weight: 700;
            padding: 6px 12px;
            border-radius: 999px;
            opacity: 0;
            transform: translateY(-8px);
            transition: all 0.3s ease;
            pointer-events: none;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .hero-slide {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            pointer-events: none;
            z-index: 10;
            will-change: transform, opacity, filter;
        }

        .hero-slide.active {
            opacity: 1;
            pointer-events: auto;
            z-index: 20;
            transform: scale(1) translateX(0);
            filter: blur(0px);
        }

        /* Transición de entrada moderna: Zoom + deslizamiento suave */
        .hero-slide.entering {
            animation: slideEnter 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
            z-index: 25;
        }

        /* Transición de salida: Zoom out + blur + desplazamiento */
        .hero-slide.exiting {
            animation: slideExit 0.9s cubic-bezier(0.55, 0.085, 0.68, 0.53) forwards;
            z-index: 20;
            opacity: 1;
        }

        @keyframes slideExit {
            0% {
                transform: scale(1) translateX(0);
                opacity: 1;
                filter: blur(0px);
            }
            100% {
                transform: scale(0.92) translateX(-60px);
                opacity: 0;
                filter: blur(6px);
            }
        }

        @keyframes slideEnter {
            0% {
                transform: scale(1.08) translateX(60px);
                opacity: 0;
                filter: blur(6px);
            }
            100% {
                transform: scale(1) translateX(0);
                opacity: 1;
                filter: blur(0px);
            }
        }

        /* Dots de navegación del slider */
        .slider-dots {
            position: absolute;
            bottom: 16px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 40;
            display: flex;
            gap: 8px;
        }

        .slider-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.4);
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border: none;
            padding: 0;
        }

        .slider-dot.active {
            background: white;
            width: 28px;
            border-radius: 4px;
            box-shadow: 0 0 12px rgba(255, 255, 255, 0.3);
        }

        .slider-dot:hover {
            background: rgba(255, 255, 255, 0.7);
            transform: scale(1.3);
        }

        /* Degradado protector sobre las imágenes de las mascotas */
        .slide-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(15, 23, 42, 0.45) 0%, rgba(15, 23, 42, 0.1) 60%);
        }

        /* ===== ESTADOS Y SIMULADOR ===== */
        .sim-state {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 16px;
            opacity: 0;
            transform: scale(0.96);
            pointer-events: none;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 5;
        }

        .sim-state.active {
            opacity: 1;
            transform: scale(1);
            pointer-events: auto;
        }

        /* ===== SCROLL REVEAL ===== */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* ===== EFECTOS DE BOTONES ===== */
        .btn-glow-teal {
            box-shadow: 0 4px 14px rgba(91, 192, 190, 0.35);
        }

        .btn-glow-teal:hover {
            box-shadow: 0 8px 25px rgba(91, 192, 190, 0.5);
        }

        /* ===== ESTILOS DE LOS MODALES ===== */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(8px);
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .modal-card {
            transform: scale(0.9);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .modal-overlay.active .modal-card {
            transform: scale(1);
        }

        /* ===== FUNCIONALIDADES CLAVE MEJORADAS ===== */
        .feature-screenshot-card {
            position: relative;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .feature-screenshot-card:hover {
            transform: translateY(-8px) scale(1.02);
        }

        .feature-screenshot-card .phone-frame img {
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .feature-screenshot-card:hover .phone-frame img {
            transform: scale(1.08);
        }

        .feature-screenshot-card .feature-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(15, 23, 42, 0.75) 0%, transparent 50%);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .feature-screenshot-card:hover .feature-overlay {
            opacity: 1;
        }

        .feature-screenshot-card:hover .feature-hover-content {
            opacity: 1;
            transform: translateY(0);
        }

        .feature-hover-content {
            opacity: 0;
            transform: translateY(12px);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .feature-screenshot-card .feature-icon-ring {
            position: relative;
            transition: all 0.4s ease;
        }

        .feature-screenshot-card:hover .feature-icon-ring {
            transform: scale(1.12) rotate(-5deg);
        }

        @keyframes shimmer {
            0% {
                background-position: -200% center;
            }

            100% {
                background-position: 200% center;
            }
        }

        .shimmer-text {
            background: linear-gradient(90deg, #5BC0BE 0%, #FF9F1C 50%, #5BC0BE 100%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 3s ease-in-out infinite;
        }

        .gradient-border-card {
            position: relative;
            background-clip: padding-box;
        }

        .gradient-border-card::before {
            content: '';
            position: absolute;
            inset: -2px;
            border-radius: inherit;
            background: linear-gradient(135deg, transparent 40%, #5BC0BE, #FF9F1C, transparent 60%);
            z-index: -1;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .gradient-border-card:hover::before {
            opacity: 1;
        }

        .active-feature-indicator {
            animation: pulseIndicator 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulseIndicator {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.5;
            }
        }

        .feature-phone-glare {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, transparent 50%);
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .feature-screenshot-card:hover .feature-phone-glare {
            opacity: 1;
        }

        /* ===== Generador visual de QR ===== */
        .simulated-qr {
            width: 100%;
            height: 100%;
            background-image: radial-gradient(#0F172A 30%, transparent 35%), radial-gradient(#0F172A 30%, transparent 35%);
            background-size: 14px 14px;
            background-position: 0 0, 7px 7px;
            opacity: 0.85;
        }

        .simulated-qr-corner {
            position: absolute;
            width: 32px;
            height: 32px;
            border: 6px solid #0F172A;
            background: #FFFFFF;
        }

        .sq-tl {
            top: 12px;
            left: 12px;
        }

        .sq-tr {
            top: 12px;
            right: 12px;
        }

        .sq-bl {
            bottom: 12px;
            left: 12px;
        }

        /* ===== NAVEGACIÓN SPA DE VISTAS ===== */
        .view-container {
            display: none;
            opacity: 0;
            transition: opacity 0.4s ease-in-out;
        }

        .view-container.active-view {
            display: block;
            opacity: 1;
        }

        /* Estilo para acordeón FAQ */
        .faq-accordion-header {
            cursor: pointer;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .faq-accordion-body {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s cubic-bezier(0, 1, 0, 1);
        }

        .faq-accordion-item.active .faq-accordion-body {
            max-height: 1000px;
            transition: max-height 0.3s cubic-bezier(1, 0, 1, 0);
        }

        .faq-accordion-item.active .faq-arrow {
            transform: rotate(180deg);
        }

        /* ===== MENÚ MÓVIL ===== */
        .nav-links.open {
            display: flex !important;
            flex-direction: column;
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid #E2E8F0;
            padding: 1.25rem 1.5rem;
            gap: 0.75rem;
            box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
            z-index: 999;
        }

        .nav-links.open li {
            width: 100%;
        }

        .nav-links.open li a {
            display: block;
            padding: 0.625rem 0;
            font-size: 0.9375rem;
        }

        .nav-links.open .btn-download-nav {
            display: inline-block;
            text-align: center;
            margin-top: 0.25rem;
            padding: 0.75rem 1.5rem;
        }
    </style>
</head>

<body class="bg-brand-lightBg text-brand-dark">

    <!-- ===== HEADER (STRICTLY LANDING NAV) ===== -->
    <header id="mainHeader"
        class="fixed top-0 left-0 w-full bg-white/80 backdrop-blur-md border-b border-brand-border z-[1000] py-4 transition-all duration-300">
        <div class="container mx-auto px-6 flex justify-between items-center">
            <a href="#home" class="logo flex items-center gap-2.5 text-2xl font-bold text-brand-dark">
                <img src="IMG-20260626-WA0027.jpg/IMG-20260626-WA0008.jpg" alt="UYWA"
                    class="w-10 h-10 object-cover rounded-full border border-brand-border shadow-sm transition-transform duration-300 hover:scale-110"
                    onerror="this.src='https://placehold.co/40x40/5BC0BE/ffffff?text=🐾'" />
                <span class="bg-gradient-to-r from-brand-teal to-brand-orange bg-clip-text text-transparent">UYWA</span>
            </a>

            <!-- Header navigation strictly points to internal landing page sections -->
            <ul class="nav-links hidden md:flex items-center gap-8 text-sm font-semibold text-slate-600" id="navLinks">
                <li><a href="#home"
                        class="hover:text-brand-dark transition-colors relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-brand-teal hover:after:w-full after:transition-all after:duration-300">Inicio</a>
                </li>
                <li><a href="#features"
                        class="hover:text-brand-dark transition-colors relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-brand-teal hover:after:w-full after:transition-all after:duration-300">Características</a>
                </li>
                <li><a href="#capturas"
                        class="hover:text-brand-dark transition-colors relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-brand-teal hover:after:w-full after:transition-all after:duration-300">Funcionalidades</a>
                </li>
                <li><a href="#status"
                        class="hover:text-brand-dark transition-colors relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-brand-teal hover:after:w-full after:transition-all after:duration-300">Clasificación</a>
                </li>
                <li><a href="#testimonios"
                        class="hover:text-brand-dark transition-colors relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:height-[2px] after:bg-brand-teal hover:after:w-full after:transition-all after:duration-300">Testimonios</a>
                </li>
                <li><a href="#"
                        class="btn-download-nav bg-gradient-to-r from-brand-teal to-brand-tealHover py-2.5 px-6 rounded-full text-white font-bold hover:scale-105 transition-transform duration-300"
                        onclick="openComingSoonModal(event)">Obtener App</a></li>
            </ul>

            <div class="menu-toggle md:hidden text-2xl cursor-pointer text-brand-dark hover:text-brand-teal transition-colors"
                id="menuToggle">
                <i class="fas fa-bars"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN VIEWS CONTAINER ===== -->
    <main class="min-h-screen pt-24">

        <!-- ==================== VISTA: HOME (LANDING PAGE) ==================== -->
        <div id="view-home" class="view-container active-view">

            <!-- ===== HERO SECTION ===== -->
            <section
                class="hero pb-20 md:pt-12 md:pb-28 bg-gradient-to-br from-teal-50/70 via-white to-orange-50/50 relative overflow-hidden"
                id="home">
                <div
                    class="absolute w-[250px] h-[250px] bg-brand-teal/10 rounded-full blur-[80px] top-10 left-[-50px] pointer-events-none">
                </div>
                <div
                    class="absolute w-[350px] h-[350px] bg-brand-orange/10 rounded-full blur-[100px] bottom-5 right-[-100px] pointer-events-none">
                </div>

                <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
                    <div class="lg:col-span-7 flex flex-col justify-center text-center lg:text-left">
                        <div class="flex flex-wrap gap-3 justify-center lg:justify-start mb-6">
                            <span
                                class="inline-flex items-center gap-1.5 bg-brand-teal/10 border border-brand-teal/20 text-teal-700 py-1.5 px-4 rounded-full text-xs font-semibold">
                                <i class="fas fa-heart"></i> +2 Mascotas a Salvo
                            </span>
                            <span
                                class="inline-flex items-center gap-1.5 bg-orange-500/10 border border-orange-500/20 text-orange-700 py-1.5 px-4 rounded-full text-xs font-semibold">
                                <i class="fas fa-star"></i> Comunidad Activa
                            </span>
                        </div>
                        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-brand-dark leading-tight mb-6">
                            Cuidamos y protegemos a tu <br class="hidden md:inline" />
                            <span class="text-brand-teal relative inline-block font-Fredoka">mejor amigo</span>
                        </h1>
                        <p class="text-slate-600 text-lg md:text-xl max-w-[540px] mx-auto lg:mx-0 mb-8 leading-relaxed">
                            UYWA es la herramienta inteligente que conecta a amantes de los animales con tecnología para
                            salvar vidas. Reporta pérdidas, gestiona adopciones responsables y ayuda en tu comunidad.
                        </p>
                        <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
                            <a href="#"
                                class="btn-primary flex items-center gap-2 bg-gradient-to-r from-brand-teal to-brand-tealHover text-white font-bold py-3.5 px-8 rounded-full btn-glow-teal hover:scale-105 transition-all duration-300"
                                onclick="openComingSoonModal(event)">
                                <i class="fab fa-apple text-xl"></i> App Store
                            </a>
                            <a href="#"
                                class="btn-primary flex items-center gap-2 bg-gradient-to-r from-brand-teal to-brand-tealHover text-white font-bold py-3.5 px-8 rounded-full btn-glow-teal hover:scale-105 transition-all duration-300"
                                onclick="openComingSoonModal(event)">
                                <i class="fab fa-google-play text-lg"></i> Google Play
                            </a>
                            <a href="#"
                                class="inline-flex items-center gap-2 border-2 border-slate-300 hover:border-brand-teal text-slate-700 hover:text-brand-teal font-bold py-3.5 px-8 rounded-full hover:bg-brand-teal/5 transition-all duration-300"
                                onclick="openQrModal(event)">
                                <i class="fas fa-qrcode"></i> Escanear QR
                            </a>
                        </div>
                    </div>

                    <div class="lg:col-span-5 flex justify-center items-center w-full">
                        <div class="slider-container w-full max-w-[420px] aspect-[4/5] relative" id="heroSlider">
                            <!-- Badge de pausa al hacer hover -->
                            <div class="slider-pause-badge">
                                <i class="fas fa-pause-circle text-[8px]"></i> Pausado
                            </div>

                            <!-- Slide 1 -->
                            <div class="hero-slide active" id="slide-dog" data-index="0">
                                <img src="https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=800"
                                    alt="Perrito feliz" class="w-full h-full object-cover rounded-[32px]" />
                                <div class="slide-overlay rounded-[32px]"></div>
                                <div class="absolute bottom-6 left-6 z-30 text-white">
                                    <h3 class="text-xl font-bold">Toby</h3>
                                    <p class="text-sm text-slate-200">Reencontrado a 200m</p>
                                </div>
                            </div>

                            <!-- Slide 2 -->
                            <div class="hero-slide" id="slide-cat" data-index="1">
                                <img src="https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&q=80&w=800"
                                    alt="Gatito tierno" class="w-full h-full object-cover rounded-[32px]" />
                                <div class="slide-overlay rounded-[32px]"></div>
                                <div class="absolute bottom-6 left-6 z-30 text-white">
                                    <h3 class="text-xl font-bold">Milo</h3>
                                    <p class="text-sm text-slate-200">Buscando un hogar feliz</p>
                                </div>
                            </div>

                            <!-- Dots de navegación -->
                            <div class="slider-dots" id="sliderDots">
                                <button class="slider-dot active" data-slide="0" aria-label="Slide 1"></button>
                                <button class="slider-dot" data-slide="1" aria-label="Slide 2"></button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ===== CARACTERÍSTICAS ===== -->
            <section class="features py-24 bg-white" id="features">
                <div class="container mx-auto px-6">
                    <div class="section-header text-center max-w-[620px] mx-auto mb-16 reveal">
                        <span
                            class="inline-flex items-center gap-1.5 bg-gradient-to-r from-brand-teal/10 to-orange-500/10 border border-brand-teal/20 text-teal-800 py-1.5 px-5 rounded-full text-xs font-semibold mb-3">
                            <i class="fas fa-star"></i> Características Únicas
                        </span>
                        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-dark mb-4">¿Por qué elegir <span class="shimmer-text">UYWA</span>?</h2>
                        <p class="text-slate-600">Nuestra tecnología se adapta a tus necesidades y a las del bienestar
                            de tus mascotas de forma inteligente.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        <!-- Card 1 -->
                        <div
                            class="feature-card bg-brand-lightBg p-8 rounded-3xl border border-brand-border hover:border-brand-teal/50 hover:shadow-xl transition-all duration-300 reveal">
                            <div
                                class="w-14 h-14 rounded-2xl bg-teal-500/10 flex items-center justify-center text-brand-teal text-2xl mb-6">
                                <i class="fas fa-map-marked-alt"></i>
                            </div>
                            <h3 class="text-xl font-bold text-brand-dark mb-2 font-Fredoka">Mapa Interactivo</h3>
                            <p class="text-slate-600">Alertas localizadas en tiempo real para que asistas de inmediato a
                                animales extraviados a pocos metros.</p>
                        </div>

                        <!-- Card 2 -->
                        <div class="feature-card bg-brand-lightBg p-8 rounded-3xl border border-brand-border hover:border-brand-teal/50 hover:shadow-xl transition-all duration-300 reveal"
                            style="transition-delay: 100ms;">
                            <div
                                class="w-14 h-14 rounded-2xl bg-orange-500/10 flex items-center justify-center text-brand-orange text-2xl mb-6">
                                <i class="fas fa-hand-holding-heart"></i>
                            </div>
                            <h3 class="text-xl font-bold text-brand-dark mb-2 font-Fredoka">Adopción Transparente</h3>
                            <p class="text-slate-600">Conecta con refugios verificados y familias de confianza sin
                                riesgo a fraudes o malas prácticas.</p>
                        </div>

                        <!-- Card 3 -->
